# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Meta (Facebook) API Configuration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Next.js Configuration
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Email Configuration
EMAIL_PROVIDER=auto                           # auto | resend | gmail | custom_smtp
EMAIL_FROM_ADDRESS=onboarding@resend.dev      # "From" address for Resend
RESEND_API_KEY=your_resend_api_key
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Custom SMTP (e.g. kontakt@piotrbajerlein.pl)
# When set, emails are sent via your own SMTP server instead of Resend/Gmail.
# Required: CUSTOM_SMTP_HOST, CUSTOM_SMTP_USER, CUSTOM_SMTP_PASSWORD
# CUSTOM_SMTP_HOST=mail.piotrbajerlein.pl
# CUSTOM_SMTP_PORT=587
# CUSTOM_SMTP_SECURE=false
# CUSTOM_SMTP_USER=kontakt@piotrbajerlein.pl
# CUSTOM_SMTP_PASSWORD=your_smtp_password
# CUSTOM_SMTP_FROM_NAME=Piotr Bajerlein - Raporty
